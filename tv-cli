#!/bin/bash

CONFIG_DIR="$HOME/.config/tv-cli"
CONFIG_FILE="$CONFIG_DIR/config"

# Create configuration folder and file on first run
if [ ! -f "$CONFIG_FILE" ]; then
    clear
    echo "🎬 Welcome to tv-cli"
    echo "It looks like this is your first time running tv-cli. Let's configure it."
    mkdir -p "$CONFIG_DIR"
    read -p "Enter your Jackett API Key: " user_api
    echo "API_KEY=\"$user_api\"" > "$CONFIG_FILE"
    echo "JACKETT_URL=\"http://localhost:9117\"" >> "$CONFIG_FILE"
    echo -e "\nConfiguration saved to $CONFIG_FILE!"
    sleep 2
fi

# Load configuration
source "$CONFIG_FILE"

if [ -z "$1" ]; then
    echo "Error: Missing search term."
    echo "Usage: tv-cli \"series name\""
    exit 1
fi

# Ensure services shut down on exit (even on Ctrl+C)
trap 'echo -e "\nShutting down search and anti-Cloudflare engines..."; systemctl --user stop jackett flaresolverr' EXIT

echo "Starting P2P tracking system (Jackett + FlareSolverr)..."
systemctl --user start flaresolverr jackett

# Smart wait loop for local API initialization
echo "Waiting for local APIs to respond..."
while ! curl -s "${JACKETT_URL}/api/v2.0/server/config" > /dev/null; do
    sleep 1
done
sleep 3 

echo "System online. Bypassing protections and searching torrents..."

# Format query for URL
query=$(echo "$1" | sed 's/ /%20/g')

# Query unified Jackett API
json=$(curl -s "${JACKETT_URL}/api/v2.0/indexers/all/results?apikey=${API_KEY}&Query=${query}")

if [ -z "$json" ] || [ "$(echo "$json" | jq '.Results | length')" -eq 0 ]; then
    echo "No results found. Try a broader search term."
    exit 1
fi

# fzf menu sorted by Seeders (descending)
seleccion=$(echo "$json" | jq -r '.Results | sort_by(.Seeders // 0) | reverse | .[] | "[\(.Size / 1048576 | floor) MB] S:\(.Seeders // 0) - \(.Title) @@ \(.MagnetUri // .Link)"' | fzf --prompt="🎬 Select your stream: ")

if [ -n "$seleccion" ]; then
    enlace=$(echo "$seleccion" | awk -F' @@ ' '{print $2}')
    clear
    
    # 1. Direct Magnet Link
    if [[ "$enlace" == magnet:* ]]; then
        echo "Connecting to P2P Magnet Link..."
        webtorrent "$enlace" --mpv
    
    # 2. HTTP Link (Jackett Proxy)
    elif [[ "$enlace" == http* ]]; then
        echo "Resolving link via Jackett proxy..."
        
        magnet_oculto=$(curl -sD - -o /dev/null "$enlace" | grep -i '^Location: *magnet:' | sed 's/^[Ll]ocation: *//I' | tr -d '\r\n')
        
        if [ -n "$magnet_oculto" ]; then
            echo "Magnet Link detected in redirection. Connecting..."
            webtorrent "$magnet_oculto" --mpv
        else
            echo "Downloading physical .torrent file..."
            archivo_tmp="/tmp/tv-cli-$(date +%s).torrent"
            curl -sL "$enlace" -o "$archivo_tmp"
            
            if [ -s "$archivo_tmp" ]; then
                webtorrent "$archivo_tmp" --mpv
                rm -f "$archivo_tmp"
            else
                echo "Error: Jackett returned an empty file."
                exit 1
            fi
        fi
    else
        echo "Unsupported link format."
        exit 1
    fi
fi
